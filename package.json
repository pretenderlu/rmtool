{
  "name": "rmtool",
  "version": "2.0.0",
  "private": true,
  "description": "Modern web-based companion for reMarkable devices with multi-device support and desktop packaging via Electron.",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:server\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && wait-on tcp:5173 && electron .",
    "dev:server": "ts-node-dev --respawn --project tsconfig.server.json src/server/index.ts",
    "build": "rimraf dist build && vite build && tsc -p tsconfig.server.json && tsc -p tsconfig.electron.json && node scripts/postbuild.cjs",
    "package": "npm run build && electron-builder",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.3",
    "ssh2": "^1.14.0",
    "ssh2-sftp-client": "^10.0.1",
    "uuid": "^9.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/uuid": "^9.0.4",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^27.1.3",
    "electron-builder": "^24.6.4",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "postcss": "^8.4.31",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.3.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "wait-on": "^7.0.1",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2"
  },
  "main": "build/electron/main.js",
  "build": {
    "appId": "io.rmtool.desktop",
    "productName": "rmtool",
    "files": [
      "dist/**/*",
      "build/server/**/*",
      "build/electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build-resources"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}